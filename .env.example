# Supabase — https://fhvlvuncymvzardotkfd.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://fhvlvuncymvzardotkfd.supabase.co
# Publishable (sb_publishable_...) o anon JWT legacy
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_publishable_or_anon_key_here

# Mismo valor sin NEXT_PUBLIC_ para el servidor en Railway/Docker
SUPABASE_URL=https://fhvlvuncymvzardotkfd.supabase.co
SUPABASE_ANON_KEY=your_publishable_or_anon_key_here

# Obligatorio para /api/contact (insert en contact_inquiries)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Recomendado en Railway: al arrancar el Docker se crea la tabla sola (sin pegar SQL).
# Supabase → Project Settings → Database → Connection string → URI → Session pooler (IPv4-friendly).
# DATABASE_URL=postgresql://postgres.[REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres
# (o SUPABASE_DATABASE_URL con el mismo valor)

# Railway asigna PORT automáticamente; local:
# PORT=3000

# Panel admin — /admin y /api/admin/* (credenciales solo en el servidor; no subir a Git)
# ADMIN_EMAIL=tu@email.com
# ADMIN_PASSWORD=contraseña_segura
# Generar secreto de sesión: openssl rand -base64 32
# ADMIN_SESSION_SECRET=

# Google Analytics 4 — Measurement ID (G-XXXXXXXXXX). Si está vacío, no se inyecta GA.
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# PostHog — Product analytics (visitas, clics, embudos, session replay).
# Convive con GA4, no lo reemplaza. Si la KEY está vacía, PostHog no se
# inicializa (no-op total). Pegá tu Project API Key (phc_...) abajo.
# Project Settings → Project API Key en https://us.posthog.com
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Blog — secret para publicar posts vía POST /api/blog (header
# x-publish-secret). Server-side only (NO lleva NEXT_PUBLIC_). Si está
# vacío, el endpoint POST rechaza todo (401). GET es público.
# BLOG_PUBLISH_SECRET=cambiá_esto_por_un_secreto_largo